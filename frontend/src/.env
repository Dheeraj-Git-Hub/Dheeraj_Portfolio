# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Connection String
# For local development:
MONGO_URI=mongodb://localhost:27017/dheeraj-portfolio
# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/dheeraj-portfolio

# Server Port
PORT=5000

# Environment
NODE_ENV=development
